# =============================================================================
# restaurant-web — environment template (RSHIR-25)
# =============================================================================
# Copy to .env.local for development; mirror these keys into the Vercel
# project's Environment Variables (Production + Preview) before first deploy.
# Every var below is referenced from app code via process.env.<NAME>.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project: qfmeojeipncuxeltnvab (eu-central-1 Frankfurt).
# URL + anon key are safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://qfmeojeipncuxeltnvab.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role: server-only. Bypasses RLS — required for tenant resolution,
# anonymous order writes, and signed-token order reads. NEVER expose to the
# browser; do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Stripe ------------------------------------------------------------------
# Use TEST keys for Preview deployments and LIVE keys for Production.
# The publishable key is shipped to the browser by lib/stripe/client.ts.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret: per-endpoint, generated when you register the
# webhook in the Stripe dashboard (or `stripe listen` for local).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- HIR Delivery API --------------------------------------------------------
# Public API exposed by pharmacy-saas-phase1 (the courier platform). The
# tenant API key is per-tenant and is provisioned by the HIR ops team.
# Used by app/api/checkout/order-finalize.ts after Stripe confirms payment.
HIR_DELIVERY_API_BASE_URL=https://pharmacy-api-production-baa6.up.railway.app
HIR_DELIVERY_API_KEY=tenant-api-key-here
