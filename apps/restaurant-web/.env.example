# Primary domain for marketing site and canonical URLs.
# Set to your apex domain (no protocol, no trailing slash).
# Default fallback in code: hirforyou.ro
NEXT_PUBLIC_PRIMARY_DOMAIN=hirforyou.ro

# Admin dashboard base URL (used for deep-links from emails/reservations).
# Default fallback: https://admin.hir.ro
NEXT_PUBLIC_ADMIN_BASE_URL=https://admin.hirforyou.ro

# Storefront base URL (used for deep-links).
# When set, takes priority over NEXT_PUBLIC_PRIMARY_DOMAIN for storefront links.
# NEXT_PUBLIC_RESTAURANT_WEB_URL=https://hirforyou.ro

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe (public key — no secret here)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
