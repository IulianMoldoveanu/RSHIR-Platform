{
  "name": "@hir/restaurant-courier",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "build:web": "next build",
    "cap:sync": "cap sync",
    "cap:android": "pnpm build:web && cap sync android && cap open android",
    "cap:ios": "pnpm build:web && cap sync ios && cap open ios",
    "build:ios": "echo 'iOS: run pnpm cap:ios on macOS with Xcode installed. See mobile/README.md.' && exit 1",
    "build:android": "echo 'Android: run pnpm cap:android with Android Studio installed. See mobile/README.md.' && exit 1",
    "start": "next start -p 3002",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@hir/supabase-types": "workspace:*",
    "@hir/ui": "workspace:*",
    "@sentry/nextjs": "^10.53.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.460.0",
    "next": "15.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
