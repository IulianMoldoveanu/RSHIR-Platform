# E2E test config. Copy to `.env.local` and fill secrets locally.
# In CI these come from repo secrets.
#
# When E2E_BASE_URL is unset, Playwright spins up `next dev` on :3002.
# When set (typically the Vercel preview URL), it skips the local server.
# E2E_BASE_URL=https://courier-beta-seven.vercel.app

# Supabase — service role for fixture seeding only. Never reach for this
# from the app under test.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Test courier — must already exist in the project's auth schema.
# Fixture creates one on first run if missing; password is set deterministically.
E2E_COURIER_EMAIL=courier-e2e@hir.test
E2E_COURIER_PASSWORD=Courier-E2E-Pass-2026
E2E_FLEET_ID=
