NEXT_PUBLIC_SUPABASE_URL=https://qfmeojeipncuxeltnvab.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# RSHIR-13: required for AI menu import (/dashboard/menu/import).
# Without it the upload UI will warn and parsing will fail.
ANTHROPIC_API_KEY=sk-ant-...

# RSHIR-12: Vercel Domains API (custom storefront domains).
# When VERCEL_TOKEN or VERCEL_PROJECT_ID is missing, the /api/domains routes +
# the Setari → Domeniu UI return `vercel_not_configured`; DB writes still
# happen so local dev works against Supabase only.
# TODO: fill VERCEL_PROJECT_ID once the restaurant-web Vercel project is
# provisioned on the Pro plan.
VERCEL_TOKEN=your-vercel-api-token
VERCEL_PROJECT_ID=
# Optional: set when the project lives under a Vercel team.
VERCEL_TEAM_ID=

# RSHIR-18: order-paid email notifications. The actual sender lives in the
# `notify-new-order` Edge Function — these are documented here for the team.
# RESEND_API_KEY is set as a Supabase function secret (NOT in this app's env).
# TODO: register hir.ro sender domain on Resend before pilot launch; until then
# the function falls back to onboarding@resend.dev (Resend's shared sandbox).
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Public base URL used by the email body to deep-link to the admin order page.
# Required by the Edge Function — set as a Supabase function secret in prod.
NEXT_PUBLIC_ADMIN_BASE_URL=http://localhost:3001
NEXT_PUBLIC_RESTAURANT_WEB_URL=http://lvh.me:3000

# RSHIR-20: comma-separated list of origins allowed to call state-changing
# API routes. Required — assertSameOrigin rejects every mutation when unset.
ALLOWED_ORIGINS=http://localhost:3001,https://admin.hir.ro
