NEXT_PUBLIC_SUPABASE_URL=https://qfmeojeipncuxeltnvab.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# RSHIR-13: required for AI menu import (/dashboard/menu/import).
# Without it the upload UI will warn and parsing will fail.
ANTHROPIC_API_KEY=sk-ant-...

# RSHIR-12: Vercel Domains API (custom storefront domains).
# When VERCEL_TOKEN or VERCEL_PROJECT_ID is missing, the /api/domains routes +
# the Setari → Domeniu UI return `vercel_not_configured`; DB writes still
# happen so local dev works against Supabase only.
# TODO: fill VERCEL_PROJECT_ID once the restaurant-web Vercel project is
# provisioned on the Pro plan.
VERCEL_TOKEN=your-vercel-api-token
VERCEL_PROJECT_ID=
# Optional: set when the project lives under a Vercel team.
VERCEL_TEAM_ID=
