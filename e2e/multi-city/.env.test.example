# Multi-city E2E test config — copy to .env.local and fill in secrets.
# Non-secret base URLs are committed here; keys live in .env.local only.
#
# When E2E_WEB_BASE_URL is unset, Playwright spins up `next dev` on :3000.
# When E2E_ADMIN_BASE_URL is unset, Playwright spins up `next dev` on :3001.
# Set both to a Vercel preview URL to run against a deployed environment:
#   E2E_WEB_BASE_URL=https://hir-restaurant-web-git-test-e2e.vercel.app
#   E2E_ADMIN_BASE_URL=https://hir-admin-git-test-e2e.vercel.app

# Supabase — service role for fixture seeding only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Platform-admin test user — must be in HIR_PLATFORM_ADMIN_EMAILS.
# The fixture creates the user on first run if missing.
E2E_ADMIN_EMAIL=platform-admin-e2e@hir.test
E2E_ADMIN_PASSWORD=Admin-E2E-Pass-2026

# Test tenant owner — used for onboarding wizard test.
# Fixture creates + attaches to a test tenant on first run.
E2E_TENANT_OWNER_EMAIL=tenant-owner-e2e@hir.test
E2E_TENANT_OWNER_PASSWORD=Owner-E2E-Pass-2026
