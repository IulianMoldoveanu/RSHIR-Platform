# HIR Datecs Companion — example env. Copy to `.env` and edit.
# Never commit the real .env (it contains your tunnel-side bearer token
# and the HMAC secret shared with HIR).

# --- HTTP & auth ---

# Port the companion HTTP server listens on. Default 7890.
COMPANION_HTTP_PORT=7890

# Shared bearer token. Must match the value HIR sends in the
# `Authorization` header. Set the SAME value when configuring the HIR
# Custom-webhook integration's `webhook_secret` (HIR uses it for HMAC,
# the companion uses it as a bearer; we keep them synonymous in V1 to
# minimize operator setup).
COMPANION_TOKEN=please-paste-the-32-hex-secret-from-hir-here

# Same value as COMPANION_TOKEN in V1 — the HIR webhook_secret is used
# for both HMAC signing and as the bearer. This pairing matches what
# HIR generates with the "Generează" button on the integrations page.
HIR_WEBHOOK_SECRET=please-paste-the-32-hex-secret-from-hir-here

# --- Datecs serial ---

# Run `npm run list-ports` to enumerate.
# Windows example: COM3
# Linux example: /dev/ttyUSB0
# macOS example: /dev/tty.usbserial-XXXX
DATECS_SERIAL_PATH=COM3

# Default 115200; some older firmware revisions ship at 9600 or 19200.
DATECS_SERIAL_BAUD=115200

# Cashier code + password programmed on the printer (Datecs service
# menu). HIR defaults to operator 1 / password 0000. Override per
# tenant if their printer uses different codes.
DATECS_OPERATOR_CODE=1
DATECS_OPERATOR_PASSWORD=0000
DATECS_TILL_NUMBER=1

# VAT group letter. 'B' = TVA redusă (HoReCa default, Legea 141/2025
# requires 11%; tenant must reprogram printer's group B from 9% to 11%
# via Datecs service menu before first use).
DATECS_DEFAULT_VAT_GROUP=B

# Set to 1 to skip the serial port entirely — useful for first-time
# setup or for testing the tunnel + auth chain without a printer.
DATECS_DRY_RUN=0
