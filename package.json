{
  "name": "hir-platform",
  "version": "0.1.0",
  "private": true,
  "description": "HIR Restaurant Suite — multi-tenant SaaS for Romanian restaurants",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "seed-demo": "node scripts/seed-demo-scenario.mjs",
    "test:e2e:multi-city": "pnpm --filter @hir/e2e-multi-city test:e2e:multi-city"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "eslint": "^8.57.1"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
